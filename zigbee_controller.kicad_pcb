	(gr_text "Recommended:\n- 2oz copper\n- U1: TPS54560\n- U4/U5: TC4427\n- U6: XT9080\n- U9: CH224K\n- Q2-Q5: IRLB3813\n- D1: MBR20045CT Schottky Diode\n- L1: 1040 22uG inductor\n- J10-J13: MKDS 5mm terminals\n- D4-D7: Optional fly-back diode\n  MBRB2045CT (Schottky)"
		(at 185.5 120.95 0)
		(layer "B.SilkS")
		(uuid "ed99dab8-fd25-40d1-8ee3-00c3a1b02969")
		(effects
			(font
				(size 1 1)
				(thickness 0.1)
			)
			(justify left bottom mirror)
		)
	)
	(gr_text "Max voltage: 24V\nMin voltage: 9V\nMax total amperage: 32A\nIO20-IO23 voltage: supply voltage\nMax amperage per channel: 18.5A	\nIO14 valtage: 5V\nMax amperage: 1.5A	\n		\nMKDS supply terminal is the \namperage bottleneck.\n32A -> 18C temperature rise on board \n"
		(at 150.5 108.95 270)
		(layer "B.SilkS")
		(uuid "021dcf06-8fe4-418b-9016-1d33d137018e")
